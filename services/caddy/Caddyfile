{
    order rate_limit before reverse_proxy

    email {$LETSENCRYPT_EMAIL:admin@example.com}
}

localhost, 127.0.0.1 {
    tls internal

    route {
        rate_limit {remote.ip} 100r/m 10000 429

        handle_path /api/* {
            reverse_proxy kong:8000
        }

        handle_path /docs/* {
            reverse_proxy mkdocs:8000
        }

        handle_path /grafana/* {
            reverse_proxy grafana:3000
        }

        handle_path /grapesjs/* {
            reverse_proxy grapesjs:3000
        }

        handle {
            reverse_proxy web:3000
        }
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

{$DOMAIN:mindfield.local} {
    tls {$LETSENCRYPT_EMAIL}

    route {
        rate_limit {remote.ip} 1000r/m 10000 429

        handle_path /api/* {
            reverse_proxy kong:8000
        }

        handle_path /docs/* {
            reverse_proxy mkdocs:8000
        }

        handle_path /grafana/* {
            reverse_proxy grafana:3000
        }

        handle_path /grapesjs/* {
            reverse_proxy grapesjs:3000
        }

        handle {
            reverse_proxy web:3000
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output stdout
        format json
    }
}
