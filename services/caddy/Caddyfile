{
  email {$LETSENCRYPT_EMAIL}
  order rate_limit before reverse_proxy
  storage redis {
    host redis
    port 6379
  }
}

redis-insight.{$DOMAIN}, mailhog.{$DOMAIN}, pgadmin.{$DOMAIN}, keycloak.{$DOMAIN}, {$DOMAIN} {
  tls {$LETSENCRYPT_EMAIL}
  @hsts host {$DOMAIN}
  header @hsts Strict-Transport-Security "max-age=31536000"
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
  log {
    output file /var/log/caddy/access.log
    format json
  }
  rate_limit {remote.ip} 6000r/m
  @keycloak host keycloak.{$DOMAIN}
  header @keycloak {
    -X-Frame-Options
    X-Frame-Options SAMEORIGIN
  }
  handle @keycloak {
    reverse_proxy keycloak:8080 {
      header_up Host {host}
    }
  }
  handle {
    reverse_proxy kong:8000 {
      header_up Host {host}
    }
  }
}

http://*.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} 302
}
