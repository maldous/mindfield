{
    order rate_limit before reverse_proxy
    email {$LETSENCRYPT_EMAIL:admin@mindfield.local}
}

(common) {
    handle_path /api/* {
        reverse_proxy kong:8000
    }
    handle_path /docs/* {
        reverse_proxy mkdocs:8000
    }
    handle_path /grafana/* {
        reverse_proxy grafana:3000
