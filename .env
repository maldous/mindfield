# MindField Kubernetes Migration Environment Variables
# Copy this to .env and fill in your values

# Project name
NAME=mindfield

# Domain configuration
DOMAIN=aldous.info
EMAIL=admin@aldous.info

# Database passwords (generate with: pwgen -s -c -n 16 1)
POSTGRES_PASSWORD=password
KC_DB_PASSWORD=password
KC_BOOTSTRAP_ADMIN_PASSWORD=password
TEMPORAL_DB_PASSWORD=password
TEMPORAL_VIS_DB_PASSWORD=password
GRAFANA_DEFAULT_PASSWORD=password

# Backup configuration
BACKUP_BUCKET=mindfield-backups
AWS_REGION=us-east-1
MINIO_ENDPOINT=http://minio.storage.svc.cluster.local:9000

# GitOps configuration
GITHUB_USER=maldous
GITHUB_REPO=mindfield

